# ─── Dashboard ────────────────────────────────────────────────
# Mot de passe d'accès au dashboard privé. Lu côté serveur uniquement
# (src/pages/api/login.ts) — surtout PAS de préfixe PUBLIC_, qui
# exposerait la valeur dans le JavaScript envoyé au navigateur.
DASHBOARD_PASSWORD=change-me

# Secret servant à dériver le jeton de session (optionnel,
# par défaut DASHBOARD_PASSWORD est utilisé)
SESSION_SECRET=change-me-aussi

# ─── HubSpot ──────────────────────────────────────────────────
# Token d'application privée HubSpot (Settings > Integrations > Private Apps)
# Lu côté serveur uniquement (src/pages/dashboard.astro) — jamais de PUBLIC_.
HUBSPOT_TOKEN=pat-eu1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
