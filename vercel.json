{
  "redirects": [
    {
      "source": "/formation",
      "destination": "/formations",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/fonts/(mr-dafoe|outfit|space-grotesk|patrick-hand)-(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/fonts/material-symbols-subset.woff2",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=2592000" }
      ]
    }
  ]
}
