---
const sessions = [
  {
    slug: 'maitriser-claude-avril-2026',
    title: 'Maîtriser Claude',
    date: '29 avril 2026',
    dateISO: '2026-04-29',
    location: 'Robelot',
    color: 'primary',
  },
  {
    slug: 'maitriser-claude-mai-2026',
    title: 'Maîtriser Claude',
    date: '20 mai 2026',
    dateISO: '2026-05-20',
    location: 'Robelot',
    color: 'secondary',
  },
];
---

<section class="py-10 md:py-12 px-6 md:px-8 bg-bg-surface-low border-y border-white/5 relative overflow-hidden">
  <!-- Subtle glow -->
  <div class="absolute inset-0 bg-gradient-to-r from-primary/5 via-transparent to-secondary/5 pointer-events-none"></div>

  <div class="max-w-[1440px] mx-auto relative z-10">
    <div class="flex flex-col md:flex-row items-center gap-6 md:gap-10 justify-between">

      <!-- Label -->
      <div class="flex items-center gap-3 flex-shrink-0">
        <span class="relative flex h-2.5 w-2.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-primary"></span>
        </span>
        <span class="font-[family-name:var(--font-headline)] font-black text-xs uppercase tracking-[0.2em] text-white">
          Sessions ouvertes
        </span>
        <span class="hidden sm:block px-2 py-0.5 rounded-full bg-secondary/20 border border-secondary/30 font-[family-name:var(--font-label)] text-[10px] uppercase tracking-widest text-secondary-light">
          Places limitées
        </span>
      </div>

      <!-- Sessions -->
      <div class="flex flex-col sm:flex-row gap-3 flex-1 justify-center">
        {sessions.map((s) => (
          <a
            href={`/formations/${s.slug}`}
            class={`group flex items-center gap-3 px-5 py-3 rounded-xl border transition-all duration-300 ${
              s.color === 'primary'
                ? 'bg-primary/10 border-primary/20 hover:bg-primary/20 hover:border-primary/40'
                : 'bg-secondary/10 border-secondary/20 hover:bg-secondary/20 hover:border-secondary/40'
            }`}
          >
            <span class={`material-symbols-outlined text-base ${s.color === 'primary' ? 'text-primary-light' : 'text-secondary-light'}`}>
              calendar_today
            </span>
            <div>
              <p class="font-[family-name:var(--font-headline)] font-bold text-white text-sm">{s.title}</p>
              <p class={`font-[family-name:var(--font-label)] text-xs ${s.color === 'primary' ? 'text-primary-light' : 'text-secondary-light'}`}>
                {s.date} · {s.location}
              </p>
            </div>
            <!-- Countdown badge -->
            <span
              class={`ml-auto font-[family-name:var(--font-headline)] font-black text-xs px-2.5 py-1 rounded-full ${
                s.color === 'primary'
                  ? 'bg-primary/20 text-primary-light'
                  : 'bg-secondary/20 text-secondary-light'
              }`}
              data-target={s.dateISO}
              data-countdown
            >
              ...
            </span>
          </a>
        ))}
      </div>

      <!-- CTA -->
      <a
        href="/formations"
        class="flex-shrink-0 gradient-cta text-white px-6 py-3 rounded-full font-[family-name:var(--font-headline)] font-bold text-xs uppercase tracking-widest neon-glow-primary hover:scale-105 transition-all duration-300 flex items-center gap-2"
      >
        Voir les sessions
        <span class="material-symbols-outlined text-sm">arrow_forward</span>
      </a>

    </div>
  </div>
</section>

<script>
  // Calculate days remaining dynamically
  document.querySelectorAll('[data-countdown]').forEach((el) => {
    const target = el.getAttribute('data-target');
    if (!target) return;
    const diff = Math.ceil((new Date(target).getTime() - Date.now()) / 86400000);
    if (diff > 0) {
      el.textContent = `J-${diff}`;
    } else if (diff === 0) {
      el.textContent = "Aujourd'hui";
    } else {
      el.textContent = 'Terminée';
      el.closest('a')?.classList.add('opacity-50', 'pointer-events-none');
    }
  });
</script>
