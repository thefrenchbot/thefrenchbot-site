---
import { Image } from 'astro:assets';
import logo from '../assets/logo.jpg';
---

<header class="fixed top-0 w-full z-50 bg-bg-base/60 backdrop-blur-xl shadow-[0_8px_32px_0_rgba(0,0,0,0.37)]">
  <div class="flex justify-between items-center px-6 md:px-8 py-4 max-w-[1440px] mx-auto">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group relative z-50">
      <Image src={logo} alt="The French Bot" width={40} height={40} class="rounded-lg" />
      <span class="text-2xl md:text-3xl gradient-text font-[family-name:var(--font-script)]">
        The French Bot
      </span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex gap-8 items-center">
      <a href="/" class="font-[family-name:var(--font-headline)] font-black text-[11px] uppercase tracking-[0.2em] text-text-secondary hover:text-text-primary transition-colors">
        Accueil
      </a>
      <a href="/formations" class="font-[family-name:var(--font-headline)] font-black text-[11px] uppercase tracking-[0.2em] text-text-secondary hover:text-text-primary transition-colors">
        Formations
      </a>
      <a href="/experts" class="font-[family-name:var(--font-headline)] font-black text-[11px] uppercase tracking-[0.2em] text-text-secondary hover:text-text-primary transition-colors">
        Experts
      </a>
      <a href="/coaching-ia" class="font-[family-name:var(--font-headline)] font-black text-[11px] uppercase tracking-[0.2em] text-text-secondary hover:text-text-primary transition-colors">
        Coaching IA
      </a>
      <a href="/agent-ia" class="font-[family-name:var(--font-headline)] font-black text-[11px] uppercase tracking-[0.2em] text-text-secondary hover:text-text-primary transition-colors">
        Agent IA
      </a>
      <a href="/blog" class="font-[family-name:var(--font-headline)] font-black text-[11px] uppercase tracking-[0.2em] text-text-secondary hover:text-text-primary transition-colors">
        Blog
      </a>
    </nav>

    <!-- Desktop CTA -->
    <div class="hidden md:flex items-center gap-4">
      <a
        href="#contact"
        class="gradient-cta text-white px-6 py-2.5 rounded-full font-[family-name:var(--font-headline)] font-black text-[10px] uppercase tracking-[0.2em] hover:scale-105 transition-transform neon-glow-primary"
      >
        Nous contacter
      </a>
    </div>

  </div>
  <div class="bg-gradient-to-b from-white/10 to-transparent h-[1px]"></div>
</header>

<!-- ===== MOBILE BOTTOM NAV BAR ===== -->
<nav
  id="bottom-nav"
  class="md:hidden fixed bottom-0 left-0 right-0 z-50"
  aria-label="Navigation principale"
  style="
    background: rgba(11,10,20,0.92);
    backdrop-filter: blur(20px);
    border-top: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 -8px 32px rgba(0,0,0,0.4), 0 -1px 0 rgba(53,36,232,0.2);
    padding-bottom: env(safe-area-inset-bottom);
  "
>
  <div style="display:flex; justify-content:space-around; align-items:center; padding: 8px 4px 6px;">

    <!-- Accueil -->
    <a href="/" class="bottom-nav-item" aria-label="Accueil" style="
      display:flex; flex-direction:column; align-items:center; gap:3px;
      padding:6px 12px; border-radius:14px;
      color: rgba(255,255,255,0.5);
      font-family: var(--font-headline, 'Outfit', sans-serif);
      font-size: 9px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
      text-decoration: none;
      transition: color 0.2s, background 0.2s;
      -webkit-tap-highlight-color: transparent;
    ">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
      Accueil
    </a>

    <!-- Formations -->
    <a href="/formations" class="bottom-nav-item" aria-label="Formations" style="
      display:flex; flex-direction:column; align-items:center; gap:3px;
      padding:6px 12px; border-radius:14px;
      color: rgba(255,255,255,0.5);
      font-family: var(--font-headline, 'Outfit', sans-serif);
      font-size: 9px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
      text-decoration: none;
      transition: color 0.2s, background 0.2s;
      -webkit-tap-highlight-color: transparent;
    ">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82zM12 3 1 9l11 6 9-4.91V17h2V9L12 3z"/></svg>
      Formations
    </a>

    <!-- Agent IA -->
    <a href="/agent-ia" class="bottom-nav-item" aria-label="Agent IA" style="
      display:flex; flex-direction:column; align-items:center; gap:3px;
      padding:6px 8px; border-radius:14px;
      color: rgba(255,255,255,0.5);
      font-family: var(--font-headline, 'Outfit', sans-serif);
      font-size: 9px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
      text-decoration: none;
      transition: color 0.2s, background 0.2s;
      -webkit-tap-highlight-color: transparent;
    ">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20 9V7c0-1.1-.9-2-2-2h-3c0-1.66-1.34-3-3-3S9 3.34 9 5H6c-1.1 0-2 .9-2 2v2c-1.66 0-3 1.34-3 3s1.34 3 3 3v4c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2v-4c1.66 0 3-1.34 3-3s-1.34-3-3-3zm-4.5 7.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm-3-4c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm0-4c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm3 0c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm-6 4c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1z"/></svg>
      Agent IA
    </a>

    <!-- Coaching — bouton central mis en valeur -->
    <a href="/coaching-ia" class="bottom-nav-item" aria-label="Coaching IA" style="
      display:flex; flex-direction:column; align-items:center; gap:3px;
      padding:6px 12px; border-radius:14px;
      color: rgba(255,255,255,0.5);
      font-family: var(--font-headline, 'Outfit', sans-serif);
      font-size: 9px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
      text-decoration: none;
      transition: color 0.2s, background 0.2s;
      -webkit-tap-highlight-color: transparent;
      position: relative;
    ">
      <div style="
        width:44px; height:44px; border-radius:50%;
        background: linear-gradient(135deg, #3524E8, #C700D3);
        display:flex; align-items:center; justify-content:center;
        box-shadow: 0 0 20px rgba(53,36,232,0.5), 0 0 40px rgba(199,0,211,0.2);
        margin-bottom:2px;
        margin-top:-14px;
      ">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="#fff" aria-hidden="true"><path d="M13 8.57c-.79 0-1.43.64-1.43 1.43s.64 1.43 1.43 1.43 1.43-.64 1.43-1.43-.64-1.43-1.43-1.43zM13 3C9.25 3 6.2 5.94 6.02 9.64L4.1 12.2c-.25.33-.01.8.4.8H6v3c0 1.1.9 2 2 2h1v3h7v-4.68c1.79-1.04 3-2.96 3-5.12C19 6.26 16.41 3 13 3z"/></svg>
      </div>
      Coaching
    </a>

    <!-- Blog -->
    <a href="/blog" class="bottom-nav-item" aria-label="Blog" style="
      display:flex; flex-direction:column; align-items:center; gap:3px;
      padding:6px 12px; border-radius:14px;
      color: rgba(255,255,255,0.5);
      font-family: var(--font-headline, 'Outfit', sans-serif);
      font-size: 9px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
      text-decoration: none;
      transition: color 0.2s, background 0.2s;
      -webkit-tap-highlight-color: transparent;
    ">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/></svg>
      Blog
    </a>

    <!-- Contact -->
    <a href="#contact" class="bottom-nav-item" aria-label="Contact" style="
      display:flex; flex-direction:column; align-items:center; gap:3px;
      padding:6px 12px; border-radius:14px;
      color: rgba(255,255,255,0.5);
      font-family: var(--font-headline, 'Outfit', sans-serif);
      font-size: 9px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
      text-decoration: none;
      transition: color 0.2s, background 0.2s;
      -webkit-tap-highlight-color: transparent;
    ">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/></svg>
      Contact
    </a>

  </div>
</nav>

<script>
  // Highlight active tab based on current path (SVG icons inherit color via currentColor)
  const path = window.location.pathname;
  document.querySelectorAll('.bottom-nav-item').forEach((link) => {
    const href = link.getAttribute('href') ?? '';
    const isActive =
      href === '/' ? path === '/' : (href !== '#contact' && path.startsWith(href));
    if (isActive) {
      (link as HTMLElement).style.color = '#bcbbff';
    }
  });
</script>
