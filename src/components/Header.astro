---
import { Image } from 'astro:assets';
import logo from '../assets/logo.jpg';
---

<header
  class="fixed top-0 w-full z-50 bg-bg-base/60 backdrop-blur-xl shadow-[0_8px_32px_0_rgba(0,0,0,0.37)]"
>
  <div class="flex justify-between items-center px-6 md:px-8 py-4 max-w-[1440px] mx-auto">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group">
      <Image
        src={logo}
        alt="The French Bot"
        width={40}
        height={40}
        class="rounded-lg"
      />
      <span class="text-2xl md:text-3xl gradient-text font-[family-name:var(--font-script)]">
        The French Bot
      </span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex gap-8 items-center">
      <a
        href="/"
        class="font-[family-name:var(--font-headline)] font-black text-[11px] uppercase tracking-[0.2em] text-text-secondary hover:text-text-primary transition-colors"
      >
        Accueil
      </a>
      <a
        href="/formations"
        class="font-[family-name:var(--font-headline)] font-black text-[11px] uppercase tracking-[0.2em] text-text-secondary hover:text-text-primary transition-colors"
      >
        Formations
      </a>
      <a
        href="/experts"
        class="font-[family-name:var(--font-headline)] font-black text-[11px] uppercase tracking-[0.2em] text-text-secondary hover:text-text-primary transition-colors"
      >
        Experts
      </a>
      <a
        href="/faq"
        class="font-[family-name:var(--font-headline)] font-black text-[11px] uppercase tracking-[0.2em] text-text-secondary hover:text-text-primary transition-colors"
      >
        FAQ
      </a>
    </nav>

    <!-- CTA -->
    <div class="flex items-center gap-4">
      <a
        href="#contact"
        class="gradient-cta text-white px-6 py-2.5 rounded-full font-[family-name:var(--font-headline)] font-black text-[10px] uppercase tracking-[0.2em] hover:scale-105 transition-transform neon-glow-primary"
      >
        Nous contacter
      </a>
    </div>
  </div>
  <div class="bg-gradient-to-b from-white/10 to-transparent h-[1px]"></div>
</header>

<!-- Mobile nav toggle script -->
<script>
  // Mobile menu (can be enhanced later with a burger menu)
</script>
