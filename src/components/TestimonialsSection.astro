---
import temoignages from '../data/temoignages.json';

const colorMap: Record<string, { bg: string; text: string; border: string }> = {
  primary:   { bg: 'bg-primary/20',   text: 'text-primary-light',   border: 'border-primary/30' },
  secondary: { bg: 'bg-secondary/20', text: 'text-secondary-light', border: 'border-secondary/30' },
  tertiary:  { bg: 'bg-tertiary/20',  text: 'text-tertiary',        border: 'border-tertiary/30' },
};
---

<section class="py-24 md:py-32 px-6 md:px-8 relative overflow-hidden">
  <!-- Background glow -->
  <div class="absolute top-1/2 left-1/4 -translate-y-1/2 w-96 h-96 bg-secondary/10 rounded-full blur-[150px] pointer-events-none"></div>

  <div class="max-w-[1440px] mx-auto">
    <!-- Header -->
    <div class="mb-16 md:mb-20 text-center space-y-4">
      <div class="inline-flex items-center gap-2 px-4 py-1 rounded-full bg-bg-surface-high border border-outline-variant/20">
        <span class="material-symbols-outlined text-secondary-light text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
        <span class="font-[family-name:var(--font-label)] text-xs uppercase tracking-[0.2em] text-text-secondary">98% de satisfaction</span>
      </div>
      <h2 class="font-[family-name:var(--font-headline)] font-black text-4xl md:text-5xl text-white uppercase tracking-[0.08em]">
        Ce qu'ils en <span class="gradient-text">disent</span>
      </h2>
      <p class="font-[family-name:var(--font-body)] text-text-secondary max-w-xl mx-auto">
        Des dirigeants de TPE et PME, pas des geeks — des résultats concrets dans leur métier.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {temoignages.map((t) => {
        const colors = colorMap[t.avatarColor] ?? colorMap.primary;
        return (
          <div class="glass-panel p-8 rounded-[2rem] border border-white/5 flex flex-col gap-6 hover:border-white/10 transition-colors duration-300">
            <!-- Quote icon -->
            <span class="material-symbols-outlined text-white/10 text-4xl" style="font-variation-settings: 'FILL' 1;">format_quote</span>

            <!-- Quote text -->
            <p class="font-[family-name:var(--font-body)] text-text-secondary leading-relaxed flex-1">
              {t.quote}
            </p>

            <!-- Metric -->
            <div class={`inline-flex items-center gap-2 self-start px-4 py-2 rounded-full ${colors.bg} border ${colors.border}`}>
              <span class="material-symbols-outlined text-sm" style={`font-variation-settings: 'FILL' 1; color: inherit;`}>trending_up</span>
              <span class={`font-[family-name:var(--font-headline)] font-black text-sm ${colors.text}`}>{t.metric}</span>
            </div>

            <!-- Author -->
            <div class="flex items-center gap-4 pt-2 border-t border-white/5">
              <div class={`w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0 ${colors.bg} border ${colors.border}`}>
                <span class={`font-[family-name:var(--font-headline)] font-black text-base ${colors.text}`}>{t.avatar}</span>
              </div>
              <div>
                <p class="font-[family-name:var(--font-headline)] font-bold text-white text-sm">{t.name}</p>
                <p class="font-[family-name:var(--font-body)] text-text-secondary text-xs">{t.role} · {t.sector}</p>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
