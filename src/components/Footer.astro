---
const currentYear = new Date().getFullYear();
---

<footer class="w-full border-t border-white/5 bg-bg-base">
  <div class="max-w-[1440px] mx-auto px-8 md:px-12 py-12 md:py-16 flex flex-col gap-10">

    <!-- Top row -->
    <div class="flex flex-col md:flex-row justify-between items-start gap-10">

      <!-- Brand -->
      <div class="space-y-3">
        <a href="/" class="text-4xl font-[family-name:var(--font-script)] gradient-text block">
          The French Bot
        </a>
        <p class="font-[family-name:var(--font-body)] text-sm text-text-secondary max-w-xs leading-relaxed">
          Formation IA et automatisation no-code pour dirigeants de TPE et PME en France.
        </p>
        <!-- Social -->
        <div class="flex gap-4 pt-2">
          <a href="https://www.instagram.com/media_machines" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-text-muted hover:text-primary-light transition-colors">
            <span class="material-symbols-outlined text-xl">photo_camera</span>
          </a>
          <a href="https://www.youtube.com/@thefrenchbot" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="text-text-muted hover:text-primary-light transition-colors">
            <span class="material-symbols-outlined text-xl">play_circle</span>
          </a>
          <a href="https://www.linkedin.com/in/julianluneau" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-text-muted hover:text-primary-light transition-colors">
            <span class="material-symbols-outlined text-xl">business_center</span>
          </a>
          <a href="https://thefrenchbot.com" target="_blank" rel="noopener noreferrer" aria-label="Site principal" class="text-text-muted hover:text-primary-light transition-colors">
            <span class="material-symbols-outlined text-xl">language</span>
          </a>
        </div>
      </div>

      <!-- Links grid -->
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-x-12 gap-y-4">
        <!-- Col 1 -->
        <div class="space-y-3">
          <p class="font-[family-name:var(--font-label)] text-[10px] uppercase tracking-[0.2em] text-text-muted">Navigation</p>
          <nav class="flex flex-col gap-2">
            {[
              { label: 'Accueil', href: '/' },
              { label: 'Formations', href: '/formations' },
              { label: 'Experts', href: '/experts' },
              { label: 'Coaching IA', href: '/coaching-ia' },
            ].map(l => (
              <a href={l.href} class="font-[family-name:var(--font-body)] text-sm text-text-secondary hover:text-white transition-colors">{l.label}</a>
            ))}
          </nav>
        </div>
        <!-- Col 2 -->
        <div class="space-y-3">
          <p class="font-[family-name:var(--font-label)] text-[10px] uppercase tracking-[0.2em] text-text-muted">The French Bot</p>
          <nav class="flex flex-col gap-2">
            {[
              { label: 'À propos', href: '/a-propos' },
              { label: 'Cas clients', href: '/cas-clients' },
              { label: 'Ressources gratuites', href: '/ressources-gratuites' },
              { label: 'FAQ', href: '/faq' },
              { label: 'Contact', href: '/#contact' },
            ].map(l => (
              <a href={l.href} class="font-[family-name:var(--font-body)] text-sm text-text-secondary hover:text-white transition-colors">{l.label}</a>
            ))}
          </nav>
        </div>
        <!-- Col 3 -->
        <div class="space-y-3">
          <p class="font-[family-name:var(--font-label)] text-[10px] uppercase tracking-[0.2em] text-text-muted">Légal</p>
          <nav class="flex flex-col gap-2">
            {[
              { label: 'Mentions légales', href: '/mentions-legales' },
              { label: 'Confidentialité', href: '/confidentialite' },
            ].map(l => (
              <a href={l.href} class="font-[family-name:var(--font-body)] text-sm text-text-secondary hover:text-white transition-colors">{l.label}</a>
            ))}
          </nav>
        </div>
      </div>

    </div>

    <!-- Bottom row -->
    <div class="flex flex-col sm:flex-row justify-between items-center gap-4 pt-8 border-t border-white/5">
      <p class="font-[family-name:var(--font-label)] text-xs tracking-widest uppercase text-text-muted">
        &copy; {currentYear} The French Bot — Julian Luneau
      </p>
      <a
        href="https://calendly.com/thefrenchbot-coaching/30min"
        target="_blank"
        rel="noopener noreferrer"
        class="font-[family-name:var(--font-label)] text-xs uppercase tracking-widest text-primary-light hover:text-white transition-colors flex items-center gap-1"
      >
        <span class="material-symbols-outlined text-sm">calendar_month</span>
        Appel découverte gratuit
      </a>
    </div>

  </div>
</footer>
