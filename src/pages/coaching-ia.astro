---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactSection from '../components/ContactSection.astro';

const coachingSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Coaching IA & Accompagnement Intelligence Artificielle",
  "description": "Coaching IA personnalisé pour dirigeants de TPE et PME. Accompagnement individuel ou en équipe pour intégrer l'intelligence artificielle et l'automatisation dans votre activité. Résultats concrets dès la première semaine.",
  "url": "https://thefrenchbot.com/coaching-ia",
  "provider": {
    "@type": "Organization",
    "name": "The French Bot",
    "url": "https://thefrenchbot.com"
  },
  "serviceType": "Coaching IA",
  "areaServed": {
    "@type": "Country",
    "name": "France"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Offres de coaching IA",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Appel découverte gratuit",
          "description": "30 minutes pour identifier vos besoins et voir comment l'IA peut vous faire gagner du temps."
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Accompagnement IA individuel",
          "description": "Coaching IA sur-mesure : automatisation de vos tâches, maîtrise de Claude, Make, Zapier."
        }
      }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Qu'est-ce que le coaching IA ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Le coaching IA est un accompagnement personnalisé pour apprendre à utiliser l'intelligence artificielle dans votre activité professionnelle. Contrairement à une formation IA classique, le coaching s'adapte à votre contexte spécifique et vos outils métier."
      }
    },
    {
      "@type": "Question",
      "name": "Combien de temps pour voir des résultats avec un coaching IA ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Dès la première semaine dans la plupart des cas. On commence par identifier votre tâche la plus chronophage et on l'automatise ou on vous apprend à la déléguer à l'IA. Sébastien a récupéré 8h par semaine dès la première semaine."
      }
    },
    {
      "@type": "Question",
      "name": "Le coaching IA est-il finançable par l'OPCO ou le CPF ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, dans la plupart des cas. OPCO si vous avez des salariés, AGEFICE si vous êtes artisan ou commerçant, CPF via MonCompteFormation. Nous vous guidons dans les démarches lors de l'appel découverte."
      }
    },
    {
      "@type": "Question",
      "name": "Faut-il être technique pour bénéficier d'un coaching IA ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Non. Claude et les outils d'IA se pilotent en français, avec des phrases normales. Aucun prérequis technique n'est demandé. Les meilleurs résultats viennent souvent de professionnels entre 40 et 60 ans sans aucune expérience en IA."
      }
    }
  ]
};
---

<BaseLayout
  title="Coaching IA & Accompagnement Intelligence Artificielle | The French Bot"
  description="Coaching IA personnalisé par Julian Luneau. Accompagnement IA sur-mesure pour dirigeants de TPE/PME : automatisation, Claude, Make, Zapier. Appel découverte gratuit. Résultats dès la 1ère semaine."
  pageSchema={coachingSchema}
>
  <!-- Hero -->
  <section class="relative min-h-[70vh] flex flex-col justify-center px-6 md:px-24 pt-32 pb-20 overflow-hidden">
    <div class="absolute top-1/4 -left-20 w-96 h-96 bg-primary/20 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-1/4 -right-20 w-96 h-96 bg-secondary/20 rounded-full blur-[120px]"></div>

    <div class="max-w-4xl mx-auto z-10 text-center space-y-8">
      <div class="inline-flex items-center gap-2 px-4 py-1 rounded-full bg-bg-surface-high border border-outline-variant/20">
        <span class="material-symbols-outlined text-tertiary text-sm" style="font-variation-settings: 'FILL' 1;">psychology</span>
        <span class="font-[family-name:var(--font-label)] text-xs uppercase tracking-[0.2em] text-text-secondary">Coaching IA personnalisé</span>
      </div>

      <h1 class="font-[family-name:var(--font-headline)] font-black text-5xl md:text-7xl leading-[0.95] tracking-tight text-white">
        Coaching IA &
        <span class="gradient-text">Accompagnement</span>
        Intelligence Artificielle
      </h1>

      <p class="font-[family-name:var(--font-body)] text-xl text-text-secondary max-w-2xl mx-auto leading-relaxed">
        Un accompagnement IA sur-mesure pour intégrer l'intelligence artificielle dans votre activité. Automatisation, Claude Code, workflows IA — avec des résultats concrets dès la première semaine.
      </p>

      <div class="flex flex-col sm:flex-row justify-center gap-6 pt-4">
        <a
          href="https://calendly.com/thefrenchbot-coaching/30min"
          target="_blank"
          rel="noopener noreferrer"
          class="gradient-cta text-white px-10 py-5 rounded-full font-[family-name:var(--font-headline)] font-bold text-sm uppercase tracking-widest neon-glow-primary hover:scale-105 transition-all duration-300 flex items-center gap-3"
        >
          Appel découverte gratuit
          <span class="material-symbols-outlined">arrow_forward</span>
        </a>
        <a
          href="/formations"
          class="glass-panel border border-outline-variant/30 text-white px-10 py-5 rounded-full font-[family-name:var(--font-headline)] font-bold text-sm uppercase tracking-widest hover:bg-white/10 transition-all duration-300"
        >
          Voir les formations IA
        </a>
      </div>
    </div>
  </section>

  <!-- Pourquoi un coaching IA -->
  <section class="py-24 px-6 md:px-8 max-w-[1440px] mx-auto">
    <div class="text-center mb-16 space-y-4">
      <h2 class="font-[family-name:var(--font-headline)] font-black text-4xl md:text-5xl text-white uppercase tracking-[0.08em]">Pourquoi un coaching IA ?</h2>
      <p class="text-text-secondary max-w-2xl mx-auto">La formation IA généraliste ne suffit pas. Le coaching IA s'adapte à votre métier, vos outils et vos objectifs spécifiques.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="glass-panel p-10 rounded-[2.5rem] border border-white/5 space-y-6">
        <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center border border-primary/30">
          <span class="material-symbols-outlined text-primary-light">person</span>
        </div>
        <h3 class="font-[family-name:var(--font-headline)] font-black text-2xl text-white uppercase">100% personnalisé</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          Votre coaching IA part de vos tâches réelles, vos outils métier et vos contraintes. Pas un programme standard — votre programme.
        </p>
      </div>

      <div class="glass-panel p-10 rounded-[2.5rem] border border-white/5 space-y-6">
        <div class="w-12 h-12 rounded-xl bg-secondary/20 flex items-center justify-center border border-secondary/30">
          <span class="material-symbols-outlined text-secondary-light">bolt</span>
        </div>
        <h3 class="font-[family-name:var(--font-headline)] font-black text-2xl text-white uppercase">Résultats rapides</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          Dès la première session, vous repartez avec une automatisation fonctionnelle. Pas de théorie — de l'action concrète.
        </p>
      </div>

      <div class="glass-panel p-10 rounded-[2.5rem] border border-white/5 space-y-6">
        <div class="w-12 h-12 rounded-xl bg-tertiary/20 flex items-center justify-center border border-tertiary/30">
          <span class="material-symbols-outlined text-tertiary">school</span>
        </div>
        <h3 class="font-[family-name:var(--font-headline)] font-black text-2xl text-white uppercase">Autonomie garantie</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          L'objectif du coaching IA est que vous n'en ayez plus besoin. Vous repartez autonome sur Claude, Make et vos workflows IA.
        </p>
      </div>
    </div>
  </section>

  <!-- Ce qu'on couvre -->
  <section class="py-20 bg-bg-surface-low px-6 md:px-8">
    <div class="max-w-[1440px] mx-auto">
      <h2 class="font-[family-name:var(--font-headline)] font-black text-4xl md:text-5xl text-white uppercase tracking-[0.08em] text-center mb-16">Ce qu'on couvre dans le coaching IA</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        {[
          { icon: 'psychology', title: 'Maîtriser Claude & ChatGPT', desc: 'Prompts avancés, artefacts, Claude Code — utiliser l\'IA comme un expert.' },
          { icon: 'auto_awesome', title: 'Automatisation no-code', desc: 'Make, Zapier, n8n — automatiser vos processus sans écrire une ligne de code.' },
          { icon: 'table_chart', title: 'IA dans vos outils métier', desc: 'Excel, PowerPoint, Gmail, CRM — l\'IA intégrée à vos outils du quotidien.' },
          { icon: 'hub', title: 'Agents IA autonomes', desc: 'Créer des assistants IA qui travaillent pour vous en continu, 24h/24.' },
          { icon: 'terminal', title: 'Claude Code', desc: 'Automatiser des tâches techniques complexes sans être développeur.' },
          { icon: 'speed', title: 'Gain de temps immédiat', desc: 'Identifier et supprimer vos 3 plus grosses pertes de temps grâce à l\'IA.' },
        ].map(item => (
          <div class="flex items-start gap-6 p-8 glass-panel rounded-2xl border border-white/5">
            <div class="w-10 h-10 rounded-xl bg-primary/20 flex items-center justify-center flex-shrink-0">
              <span class="material-symbols-outlined text-primary-light text-lg">{item.icon}</span>
            </div>
            <div>
              <h3 class="font-[family-name:var(--font-headline)] font-bold text-white text-lg mb-2">{item.title}</h3>
              <p class="text-text-secondary text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Témoignages -->
  <section class="py-24 px-6 md:px-8 max-w-[1440px] mx-auto">
    <h2 class="font-[family-name:var(--font-headline)] font-black text-4xl md:text-5xl text-white uppercase tracking-[0.08em] text-center mb-16">Ils ont été accompagnés</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <div class="glass-panel p-10 rounded-[2rem] border border-white/5 space-y-6">
        <p class="text-white text-lg leading-relaxed italic">"Grâce au coaching IA de Julian, j'ai automatisé mes devis et récupéré 8h par semaine. En 2 sessions seulement."</p>
        <div>
          <p class="font-bold text-white">Sébastien Sebach</p>
          <p class="text-text-secondary text-sm">Dirigeant TPE</p>
        </div>
      </div>
      <div class="glass-panel p-10 rounded-[2rem] border border-white/5 space-y-6">
        <p class="text-white text-lg leading-relaxed italic">"L'accompagnement IA m'a permis de déléguer 3h de travail répétitif par semaine à Claude. Je me concentre sur ce qui compte vraiment."</p>
        <div>
          <p class="font-bold text-white">Rémy</p>
          <p class="text-text-secondary text-sm">Ninkasi</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-24 px-6 md:px-8 max-w-4xl mx-auto">
    <h2 class="font-[family-name:var(--font-headline)] font-black text-4xl text-white uppercase tracking-[0.08em] text-center mb-16">Questions sur le coaching IA</h2>
    <div class="space-y-4">
      {[
        {
          q: "Qu'est-ce que le coaching IA ?",
          a: "Le coaching IA est un accompagnement personnalisé pour apprendre à utiliser l'intelligence artificielle dans votre activité professionnelle. Contrairement à une formation IA classique, le coaching s'adapte à votre contexte spécifique et vos outils métier."
        },
        {
          q: "Combien de temps pour voir des résultats ?",
          a: "Dès la première semaine dans la plupart des cas. On commence par identifier votre tâche la plus chronophage et on l'automatise. Sébastien a récupéré 8h par semaine dès la première session."
        },
        {
          q: "Le coaching IA est-il finançable ?",
          a: "Oui, dans la plupart des cas. OPCO si vous avez des salariés, AGEFICE si vous êtes artisan ou commerçant, CPF via MonCompteFormation. Nous vous guidons dans les démarches lors de l'appel découverte gratuit."
        },
        {
          q: "Faut-il être technique ?",
          a: "Non. Claude et les outils IA se pilotent en français, avec des phrases normales. Aucun prérequis technique. Les meilleurs résultats viennent souvent de professionnels de 40-60 ans sans expérience en IA."
        }
      ].map(faq => (
        <div class="glass-panel p-8 rounded-2xl border border-white/5">
          <h3 class="font-[family-name:var(--font-headline)] font-bold text-white text-lg mb-4">{faq.q}</h3>
          <p class="text-text-secondary leading-relaxed">{faq.a}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-6 md:px-8">
    <div class="max-w-3xl mx-auto glass-panel p-12 md:p-20 rounded-[3rem] border border-white/10 text-center space-y-8 relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-primary via-secondary to-tertiary"></div>
      <h2 class="font-[family-name:var(--font-headline)] font-black text-4xl md:text-5xl text-white uppercase leading-tight">
        Prêt pour votre
        <span class="gradient-text">coaching IA ?</span>
      </h2>
      <p class="text-text-secondary text-lg max-w-xl mx-auto">
        30 minutes de découverte, gratuit, sans engagement. On identifie ensemble comment l'IA peut transformer votre quotidien professionnel.
      </p>
      <a
        href="https://calendly.com/thefrenchbot-coaching/30min"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-white text-bg-base px-10 py-5 rounded-full font-[family-name:var(--font-headline)] font-black text-base uppercase tracking-widest hover:scale-105 transition-all duration-300 shadow-[0_0_50px_rgba(255,255,255,0.2)]"
      >
        Réserver l'appel gratuit
        <span class="material-symbols-outlined">arrow_forward</span>
      </a>
    </div>
  </section>

  <ContactSection />
</BaseLayout>
