---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactSection from '../components/ContactSection.astro';

const experts = [
  {
    name: 'Julian Luneau',
    role: 'Fondateur & Formateur IA',
    description: "Expert en intelligence artificielle, automatisation no-code et prompt engineering. Fondateur de The French Bot, il accompagne les entreprises dans leur transformation IA.",
    icons: ['terminal', 'auto_awesome', 'rocket_launch'],
    borderClass: 'shadow-[0_0_15px_-5px_rgba(53,36,232,0.5)] border border-primary-light/10',
    roleColor: 'text-primary-dim',
    iconColor: 'text-primary-light',
  },
  {
    name: 'Expert Automatisation',
    role: 'Spécialiste No-Code & Workflows',
    description: "Maîtrise des plateformes Make, n8n, Zapier et des intégrations API. Conçoit des automatisations sur-mesure pour PME et indépendants.",
    icons: ['account_tree', 'integration_instructions', 'bolt'],
    borderClass: 'shadow-[0_0_15px_-5px_rgba(199,0,211,0.5)] border border-secondary-light/10',
    roleColor: 'text-secondary-light',
    iconColor: 'text-secondary-light',
  },
  {
    name: 'Expert Stratégie IA',
    role: 'Consultant Transformation Digitale',
    description: "Accompagne les dirigeants dans la définition et la mise en œuvre de leur stratégie d'adoption de l'IA à l'échelle de l'entreprise.",
    icons: ['analytics', 'groups', 'trending_up'],
    borderClass: 'shadow-[0_0_15px_-5px_rgba(100,216,217,0.5)] border border-tertiary/10',
    roleColor: 'text-tertiary',
    iconColor: 'text-tertiary',
  },
];
---

<BaseLayout
  title="Experts & Pédagogie — The French Bot"
  description="Découvrez l'équipe d'experts The French Bot et notre approche pédagogique unique. Des praticiens IA au service de votre montée en compétences."
>
  <!-- Hero Title -->
  <section class="pt-32 pb-16 md:pb-32 px-6 md:px-12 lg:px-24 max-w-[1440px] mx-auto">
    <div class="max-w-4xl">
      <span class="font-[family-name:var(--font-label)] text-tertiary tracking-[0.3em] uppercase text-xs mb-4 block">L'équipe</span>
      <h1 class="font-[family-name:var(--font-headline)] text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-black uppercase tracking-tight leading-none mb-8">
        Nos <span class="gradient-text">Experts</span>
      </h1>
      <p class="text-lg md:text-xl text-text-secondary max-w-2xl font-light leading-relaxed">
        Guidés par des praticiens de l'IA qui déploient ces outils au quotidien dans de vraies entreprises françaises.
      </p>
    </div>
  </section>

  <!-- Expert Cards -->
  <section class="mb-32 md:mb-48 px-6 md:px-12 lg:px-24 max-w-[1440px] mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {experts.map((expert, i) => (
        <div class:list={['glass-panel rounded-3xl p-8 group hover:translate-y-[-8px] transition-all duration-500', expert.borderClass, i === 2 && 'lg:translate-y-12']}>
          <div class="relative w-full aspect-square mb-8 overflow-hidden rounded-2xl bg-gradient-to-br from-bg-surface-high to-bg-surface flex items-center justify-center">
            <span class="material-symbols-outlined text-text-muted/30 text-[60px] md:text-[100px] group-hover:text-primary-light/40 transition-colors duration-500">person</span>
            <div class="absolute inset-0 bg-gradient-to-t from-bg-base to-transparent opacity-60"></div>
          </div>
          <div class="flex flex-col gap-2">
            <span class:list={['font-[family-name:var(--font-label)] text-xs tracking-widest uppercase', expert.roleColor]}>{expert.role}</span>
            <h3 class="font-[family-name:var(--font-headline)] text-2xl md:text-3xl font-black uppercase tracking-[0.05em]">{expert.name}</h3>
            <p class="text-text-secondary text-sm mt-2 leading-relaxed">{expert.description}</p>
            <div class="flex gap-3 mt-6">
              {expert.icons.map((icon) => (
                <span class:list={['material-symbols-outlined text-xl', expert.iconColor]}>{icon}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Methodology -->
  <section class="mb-32 md:mb-48 px-6 md:px-12 lg:px-24 max-w-[1440px] mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      <!-- Left column -->
      <div class="lg:col-span-5 mb-8 lg:mb-0">
        <span class="font-[family-name:var(--font-label)] text-primary-light tracking-[0.3em] uppercase text-xs mb-4 block">Notre approche</span>
        <h2 class="font-[family-name:var(--font-headline)] text-4xl md:text-5xl lg:text-7xl font-black uppercase tracking-tight leading-tight mb-8">
          Notre <br /><span class="font-[family-name:var(--font-script)] normal-case gradient-text">Pédagogie</span>
        </h2>
        <p class="text-text-secondary mb-8 text-lg leading-relaxed">
          Nous ne faisons pas que transmettre des connaissances — nous formons des praticiens. Notre méthodologie combine rigueur théorique et application terrain immédiate.
        </p>

        <div class="space-y-6">
          <div class="flex items-start gap-4 p-4 rounded-xl hover:bg-bg-surface-low transition-colors group">
            <div class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center shrink-0 group-hover:bg-primary/40 transition-colors">
              <span class="material-symbols-outlined text-primary-light">psychology</span>
            </div>
            <div>
              <h4 class="font-[family-name:var(--font-headline)] text-xl font-black uppercase tracking-tight mb-1">Apprentissage par la pratique</h4>
              <p class="text-sm text-text-secondary/80">Chaque concept est immédiatement mis en application sur des cas réels.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 p-4 rounded-xl hover:bg-bg-surface-low transition-colors group">
            <div class="w-12 h-12 rounded-full bg-secondary/20 flex items-center justify-center shrink-0 group-hover:bg-secondary/40 transition-colors">
              <span class="material-symbols-outlined text-secondary-light">analytics</span>
            </div>
            <div>
              <h4 class="font-[family-name:var(--font-headline)] text-xl font-black uppercase tracking-tight mb-1">Résultats mesurables</h4>
              <p class="text-sm text-text-secondary/80">Des objectifs clairs, des livrables concrets et des compétences vérifiables.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right column: Bento grid -->
      <div class="lg:col-span-7 grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Cell 1 -->
        <div class="bg-bg-surface-low rounded-3xl p-8 md:p-10 border border-white/5 relative overflow-hidden group">
          <div class="absolute -top-24 -right-24 w-64 h-64 bg-primary/10 rounded-full blur-[80px] group-hover:bg-primary/20 transition-all"></div>
          <h3 class="font-[family-name:var(--font-headline)] text-3xl md:text-4xl font-black uppercase tracking-tight mb-4 relative z-10">01<br />Formations intensives</h3>
          <p class="text-text-secondary leading-relaxed relative z-10">Des sprints immersifs focalisés sur le déploiement rapide et l'autonomie technique.</p>
          <div class="mt-6 md:mt-8 flex items-center gap-2 text-primary-light font-[family-name:var(--font-label)] text-xs tracking-widest uppercase relative z-10">
            Voir le catalogue <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </div>
        </div>
        <!-- Cell 2 -->
        <div class="bg-bg-surface-high rounded-3xl p-8 md:p-10 border border-white/5 relative overflow-hidden group">
          <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-secondary/10 rounded-full blur-[80px] group-hover:bg-secondary/20 transition-all"></div>
          <h3 class="font-[family-name:var(--font-headline)] text-3xl md:text-4xl font-black uppercase tracking-tight mb-4 relative z-10">02<br />Pratique terrain</h3>
          <p class="text-text-secondary leading-relaxed relative z-10">Accès à nos outils, templates et workflows pour pratiquer immédiatement.</p>
          <div class="mt-6 md:mt-8 flex items-center gap-2 text-secondary-light font-[family-name:var(--font-label)] text-xs tracking-widest uppercase relative z-10">
            Découvrir <span class="material-symbols-outlined text-sm">rocket_launch</span>
          </div>
        </div>
        <!-- Cell 3 -->
        <div class="md:col-span-2 bg-gradient-to-br from-bg-surface-low to-bg-base rounded-3xl p-8 md:p-10 border border-white/5 relative group min-h-[250px] md:min-h-[300px] flex flex-col justify-end">
          <h3 class="font-[family-name:var(--font-headline)] text-3xl md:text-4xl font-black uppercase tracking-tight mb-4 relative z-10">03 Études de cas</h3>
          <p class="text-text-secondary leading-relaxed max-w-lg relative z-10">
            Analysez des déploiements IA réels dans des PME et grandes entreprises françaises. Apprenez de nos succès et de nos erreurs.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="mb-24 md:mb-32 px-6 md:px-12 lg:px-24 max-w-[1440px] mx-auto">
    <div class="relative rounded-[3rem] overflow-hidden gradient-cta py-20 md:py-24 px-8 md:px-12 text-center group">
      <div class="absolute inset-0 bg-gradient-to-r from-primary via-secondary to-primary opacity-50 blur-3xl scale-150"></div>
      <div class="relative z-10 max-w-2xl mx-auto">
        <h2 class="font-[family-name:var(--font-headline)] text-4xl md:text-5xl lg:text-6xl font-black uppercase tracking-[0.05em] mb-8 text-white">
          Rejoignez la prochaine session
        </h2>
        <p class="text-white/80 text-lg mb-10 md:mb-12">
          Les inscriptions sont ouvertes. Places limitées par session pour garantir un accompagnement de qualité.
        </p>
        <div class="flex flex-col sm:flex-row gap-6 justify-center">
          <a href="/formations" class="bg-white text-primary px-8 md:px-10 py-4 rounded-full font-[family-name:var(--font-headline)] font-bold text-lg tracking-tight hover:scale-105 transition-transform active:scale-95 shadow-2xl">
            Voir les formations
          </a>
          <a href="#contact" class="bg-white/10 backdrop-blur-md text-white border border-white/20 px-8 md:px-10 py-4 rounded-full font-[family-name:var(--font-headline)] font-bold text-lg tracking-tight hover:bg-white/20 transition-all active:scale-95">
            Nous contacter
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <ContactSection />
</BaseLayout>
