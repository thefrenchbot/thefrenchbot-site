---
export const prerender = false;

import { createHash } from 'crypto';
import DashboardLayout from '../layouts/DashboardLayout.astro';

// ─── Auth (100% côté serveur — le mot de passe ne quitte jamais le serveur) ──
const DASHBOARD_PASSWORD = import.meta.env.DASHBOARD_PASSWORD;
const SESSION_SECRET = import.meta.env.SESSION_SECRET || DASHBOARD_PASSWORD || '';
const EXPECTED_TOKEN = createHash('sha256').update(SESSION_SECRET + ':tfb-dashboard').digest('hex');

const sessionCookie = Astro.cookies.get('tfb_session')?.value;
const isAuthed = Boolean(SESSION_SECRET) && sessionCookie === EXPECTED_TOKEN;
const hasError = Astro.url.searchParams.get('error') === '1';

// ─── Formations data ──────────────────────────────────────────────────────────
const formations = [
  {
    id: 1,
    title: "Claude et son environnement",
    dateISO: "2026-04-29",
    dateDisplay: "Mercredi 29 avril 2026",
    location: "Robelot",
    liveDuration: "7h",
    elearningDuration: "14h",
    accent: "#3524E8",
    accentLight: "#c2c1ff",
    modules: [
      { icon: "table_chart",    label: "Claude dans Excel" },
      { icon: "slideshow",      label: "Claude dans PowerPoint" },
      { icon: "auto_awesome",   label: "Les artefacts dans Claude" },
      { icon: "terminal",       label: "Claude Code" },
      { icon: "image",          label: "Concurrents & création d'images (NanoBanana)" },
      { icon: "psychology",     label: "Créer un second cerveau IA multi-LLM" },
      { icon: "compare_arrows", label: "ChatGPT, Gemini & autres LLMs" },
    ],
  },
  {
    id: 2,
    title: "Maîtriser Claude",
    dateISO: "2026-05-20",
    dateDisplay: "Mercredi 20 mai 2026",
    location: "Robelot",
    liveDuration: "7h",
    elearningDuration: "14h",
    accent: "#C700D3",
    accentLight: "#ffa9fb",
    modules: [
      { icon: "table_chart",    label: "Claude dans Excel" },
      { icon: "slideshow",      label: "Claude dans PowerPoint" },
      { icon: "auto_awesome",   label: "Les artefacts dans Claude" },
      { icon: "terminal",       label: "Claude Code" },
      { icon: "image",          label: "Concurrents & création d'images (NanoBanana)" },
      { icon: "psychology",     label: "Créer un second cerveau IA multi-LLM" },
      { icon: "compare_arrows", label: "ChatGPT, Gemini & autres LLMs" },
    ],
  },
];

const today = new Date();
const formationsData = formations.map(f => ({
  ...f,
  daysUntil: Math.max(0, Math.ceil(
    (new Date(f.dateISO).getTime() - today.getTime()) / (1000 * 60 * 60 * 24)
  )),
}));

// ─── HubSpot (server-side — token jamais exposé au client) ───────────────────
const HUBSPOT_TOKEN = import.meta.env.HUBSPOT_TOKEN;

interface HubContact {
  id: string;
  properties: { firstname?: string; lastname?: string; email?: string; createdate?: string; };
}

const hubspot = {
  connected: false,
  totalContacts: 0,
  totalDeals: 0,
  recentContacts: [] as HubContact[],
  error: '',
  builtAt: new Date().toLocaleDateString('fr-FR', {
    day: 'numeric', month: 'long', year: 'numeric',
    hour: '2-digit', minute: '2-digit',
  }),
};

if (isAuthed && HUBSPOT_TOKEN) {
  try {
    const h = { Authorization: `Bearer ${HUBSPOT_TOKEN}` };
    const [cRes, dRes] = await Promise.all([
      fetch(
        'https://api.hubapi.com/crm/v3/objects/contacts?limit=8&properties=firstname,lastname,email,createdate&sort=-createdate',
        { headers: h }
      ),
      fetch('https://api.hubapi.com/crm/v3/objects/deals?limit=1', { headers: h }),
    ]);

    if (cRes.ok) {
      const d = await cRes.json();
      hubspot.connected  = true;
      hubspot.totalContacts = d.total ?? 0;
      hubspot.recentContacts = d.results ?? [];
    } else {
      hubspot.error = `Erreur API ${cRes.status}`;
    }

    if (dRes.ok) {
      const d = await dRes.json();
      hubspot.totalDeals = d.total ?? 0;
    }
  } catch (e: any) {
    hubspot.error = e?.message ?? 'Connexion impossible';
  }
}

function contactName(c: HubContact) {
  const p = c.properties;
  return [p.firstname, p.lastname].filter(Boolean).join(' ') || p.email || '—';
}

function relDate(str?: string) {
  if (!str) return '';
  const d = Math.floor((Date.now() - new Date(str).getTime()) / 86400000);
  if (d === 0) return "Aujourd'hui";
  if (d === 1) return 'Hier';
  return `Il y a ${d}j`;
}
---

<DashboardLayout title="Dashboard — The French Bot">

{!isAuthed ? (
  <!-- ═══════════════════════════════════════════════
       LOGIN — affiché uniquement si non connecté
       Le dashboard n'est PAS dans ce HTML.
  ════════════════════════════════════════════════ -->
  <div class="fixed inset-0 z-50 flex items-center justify-center bg-bg-base">
    <div class="absolute top-1/3 left-1/4 w-[500px] h-[500px] rounded-full bg-primary/15 blur-[140px] pointer-events-none"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] rounded-full bg-secondary/15 blur-[140px] pointer-events-none"></div>

    <div class="relative z-10 w-full max-w-sm mx-4">
      <div class="text-center mb-8 space-y-1">
        <p class="font-[family-name:var(--font-script)] text-5xl gradient-text leading-none">The French Bot</p>
        <p class="font-[family-name:var(--font-headline)] font-black text-xs uppercase tracking-[0.35em] text-text-muted mt-3">
          Tableau de bord privé
        </p>
      </div>

      <div class="glass-panel rounded-3xl border border-white/10 p-8 space-y-5">
        <form method="POST" action="/api/login" class="space-y-5">
          <div>
            <label
              for="pwd-input"
              class="font-[family-name:var(--font-headline)] font-bold text-[10px] uppercase tracking-[0.25em] text-text-secondary block mb-2"
            >
              Mot de passe
            </label>
            <input
              id="pwd-input"
              name="password"
              type="password"
              placeholder="••••••••••••"
              class="w-full bg-bg-surface border border-outline-variant/40 rounded-xl px-4 py-3.5 text-white placeholder-text-muted font-[family-name:var(--font-body)] text-sm focus:outline-none focus:border-primary/70 focus:ring-1 focus:ring-primary/30 transition-all"
              autocomplete="current-password"
              autofocus
            />
          </div>

          {hasError && (
            <p class="text-xs text-center font-[family-name:var(--font-body)]" style="color: #ffb4ab;">
              Mot de passe incorrect. Réessaie.
            </p>
          )}

          <button
            type="submit"
            class="w-full gradient-cta text-white py-3.5 rounded-xl font-[family-name:var(--font-headline)] font-black text-xs uppercase tracking-[0.25em] neon-glow-primary hover:scale-[1.02] active:scale-[0.98] transition-all duration-200"
          >
            Accéder au dashboard
          </button>
        </form>
      </div>

      <p class="text-center text-text-muted text-xs font-[family-name:var(--font-body)] mt-6">
        The French Bot © 2026 — Accès réservé
      </p>
    </div>
  </div>

) : (

  <!-- ═══════════════════════════════════════════════
       DASHBOARD — affiché uniquement si connecté
  ════════════════════════════════════════════════ -->
  <div id="dashboard-app" class="h-screen flex">

    <!-- ─── SIDEBAR ──────────────────────────────── -->
    <aside class="w-64 flex-shrink-0 h-full flex flex-col glass-panel border-r border-white/5 z-10">

      <div class="px-6 py-5 border-b border-white/5 flex-shrink-0">
        <p class="font-[family-name:var(--font-script)] text-3xl gradient-text leading-none">The French Bot</p>
        <p class="font-[family-name:var(--font-headline)] font-bold text-[9px] uppercase tracking-[0.3em] text-text-muted mt-1.5">
          Dashboard privé
        </p>
      </div>

      <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
        <button data-tab="formations"
          class="tab-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl text-left transition-all duration-200">
          <span class="material-symbols-outlined text-xl flex-shrink-0">school</span>
          <span class="font-[family-name:var(--font-headline)] font-bold text-xs uppercase tracking-wider">Formations</span>
        </button>
        <button data-tab="coaching"
          class="tab-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl text-left transition-all duration-200">
          <span class="material-symbols-outlined text-xl flex-shrink-0">handshake</span>
          <span class="font-[family-name:var(--font-headline)] font-bold text-xs uppercase tracking-wider">Coaching</span>
        </button>
        <button data-tab="hubspot"
          class="tab-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl text-left transition-all duration-200">
          <span class="material-symbols-outlined text-xl flex-shrink-0">contacts</span>
          <span class="font-[family-name:var(--font-headline)] font-bold text-xs uppercase tracking-wider">CRM HubSpot</span>
        </button>
        <button data-tab="contenu"
          class="tab-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl text-left transition-all duration-200">
          <span class="material-symbols-outlined text-xl flex-shrink-0">video_library</span>
          <span class="font-[family-name:var(--font-headline)] font-bold text-xs uppercase tracking-wider">Contenu</span>
        </button>
        <button data-tab="automation"
          class="tab-btn w-full flex items-center gap-3 px-4 py-3 rounded-xl text-left transition-all duration-200">
          <span class="material-symbols-outlined text-xl flex-shrink-0">hub</span>
          <span class="font-[family-name:var(--font-headline)] font-bold text-xs uppercase tracking-wider">Automatisation n8n</span>
        </button>
      </nav>

      <div class="px-4 py-4 border-t border-white/5 flex-shrink-0">
        <div class="flex items-center gap-3 px-2 mb-3">
          <div class="w-9 h-9 rounded-full gradient-cta flex items-center justify-center text-white text-xs font-bold flex-shrink-0 font-[family-name:var(--font-headline)]">JL</div>
          <div class="min-w-0">
            <p class="font-[family-name:var(--font-headline)] font-black text-[11px] text-white uppercase tracking-wider truncate">Julian Luneau</p>
            <p class="text-text-muted text-[10px] font-[family-name:var(--font-body)] truncate">The French Bot</p>
          </div>
        </div>
        <form method="POST" action="/api/logout">
          <button
            type="submit"
            class="w-full flex items-center gap-2 px-3 py-2 rounded-xl text-text-muted hover:text-white hover:bg-white/5 transition-all duration-200 text-xs font-[family-name:var(--font-body)]"
          >
            <span class="material-symbols-outlined text-base">logout</span>
            Déconnexion
          </button>
        </form>
      </div>
    </aside>


    <!-- ─── MAIN CONTENT ─────────────────────────── -->
    <main class="flex-1 overflow-y-auto flex flex-col min-w-0">

      <div class="sticky top-0 z-10 glass-panel border-b border-white/5 px-8 py-4 flex items-center justify-between flex-shrink-0">
        <h1 id="page-title"
          class="font-[family-name:var(--font-headline)] font-black text-lg uppercase tracking-[0.15em] text-white">
          Formations
        </h1>
        <div class="flex items-center gap-6">
          <p id="current-date" class="font-[family-name:var(--font-body)] text-xs text-text-muted"></p>
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-tertiary"></span>
            <span class="font-[family-name:var(--font-body)] text-xs text-text-secondary">En ligne</span>
          </div>
        </div>
      </div>


      <!-- ═══ TAB : FORMATIONS ══════════════════════ -->
      <div id="tab-formations" class="flex-1 p-8 space-y-8">

        <div class="grid grid-cols-3 gap-4">
          <div class="glass-card rounded-2xl p-6 border border-white/5 space-y-1">
            <p class="font-[family-name:var(--font-body)] text-[10px] uppercase tracking-[0.25em] text-text-muted">Sessions</p>
            <p class="font-[family-name:var(--font-headline)] font-black text-5xl text-white">2</p>
            <p class="font-[family-name:var(--font-body)] text-xs text-text-secondary">Programmées en 2026</p>
          </div>
          <div class="glass-card rounded-2xl p-6 border border-white/5 space-y-1">
            <p class="font-[family-name:var(--font-body)] text-[10px] uppercase tracking-[0.25em] text-text-muted">Prochaine session</p>
            <p id="days-countdown" class="font-[family-name:var(--font-headline)] font-black text-5xl text-white">{formationsData[0].daysUntil}</p>
            <p class="font-[family-name:var(--font-body)] text-xs text-text-secondary">Jours restants</p>
          </div>
          <div class="glass-card rounded-2xl p-6 border border-white/5 space-y-1">
            <p class="font-[family-name:var(--font-body)] text-[10px] uppercase tracking-[0.25em] text-text-muted">Contacts HubSpot</p>
            <p class={`font-[family-name:var(--font-headline)] font-black text-5xl ${hubspot.connected ? 'text-white' : 'text-text-muted'}`}>
              {hubspot.connected ? hubspot.totalContacts : '—'}
            </p>
            <p class="font-[family-name:var(--font-body)] text-xs text-text-secondary flex items-center gap-1">
              {hubspot.connected
                ? <><span class="w-1.5 h-1.5 rounded-full bg-tertiary inline-block"></span> Connecté</>
                : 'Non connecté'
              }
            </p>
          </div>
        </div>

        <div class="flex items-end gap-4">
          <h2 class="font-[family-name:var(--font-headline)] font-black text-3xl uppercase tracking-tight text-white">
            Mes formations
          </h2>
          <span class="font-[family-name:var(--font-hand)] text-xl text-text-muted pb-0.5">— 2026</span>
        </div>

        <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
          {formationsData.map((f) => (
            <div class="glass-panel rounded-3xl border border-white/5 overflow-hidden relative flex flex-col">
              <div class="h-[3px] w-full flex-shrink-0" style={`background: linear-gradient(90deg, ${f.accent}, ${f.accentLight}40)`}></div>
              <div class="p-7 flex flex-col gap-6 flex-1">
                <div class="flex items-start justify-between gap-4">
                  <div class="space-y-3 flex-1 min-w-0">
                    <div class="flex items-center gap-2 flex-wrap">
                      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-[family-name:var(--font-headline)] font-bold uppercase tracking-widest border"
                        style={`color:${f.accentLight}; border-color:${f.accent}50; background:${f.accent}18`}>
                        <span class="w-1.5 h-1.5 rounded-full animate-pulse" style={`background:${f.accentLight}`}></span>
                        À venir
                      </span>
                      <span class="px-3 py-1 rounded-full text-[10px] font-[family-name:var(--font-headline)] font-bold uppercase tracking-widest bg-white/5 text-text-muted border border-white/10">
                        J — {f.daysUntil}
                      </span>
                    </div>
                    <h3 class="font-[family-name:var(--font-headline)] font-black text-2xl text-white uppercase tracking-tight leading-tight">
                      {f.title}
                    </h3>
                  </div>
                  <div class="flex-shrink-0 w-12 h-12 rounded-2xl flex items-center justify-center border"
                    style={`background:${f.accent}18; border-color:${f.accent}40`}>
                    <span class="material-symbols-outlined text-xl" style={`color:${f.accentLight}`}>school</span>
                  </div>
                </div>

                <div class="flex items-center gap-5">
                  <div class="flex items-center gap-1.5 text-text-secondary font-[family-name:var(--font-body)] text-sm">
                    <span class="material-symbols-outlined text-base">calendar_today</span>
                    <span>{f.dateDisplay}</span>
                  </div>
                  <div class="flex items-center gap-1.5 text-text-secondary font-[family-name:var(--font-body)] text-sm">
                    <span class="material-symbols-outlined text-base">location_on</span>
                    <span>{f.location}</span>
                  </div>
                </div>

                <div class="flex items-center gap-3">
                  <div class="flex items-center gap-2 px-4 py-2 rounded-xl bg-white/5 border border-white/10">
                    <span class="material-symbols-outlined text-base" style={`color:${f.accentLight}`}>videocam</span>
                    <span class="font-[family-name:var(--font-headline)] font-bold text-sm text-white uppercase tracking-wider">
                      {f.liveDuration} Live
                    </span>
                  </div>
                  <span class="text-text-muted font-[family-name:var(--font-body)] text-xs">+</span>
                  <div class="flex items-center gap-2 px-4 py-2 rounded-xl bg-white/5 border border-white/10">
                    <span class="material-symbols-outlined text-base" style={`color:${f.accentLight}`}>play_circle</span>
                    <span class="font-[family-name:var(--font-headline)] font-bold text-sm text-white uppercase tracking-wider">
                      {f.elearningDuration} E-learning
                    </span>
                  </div>
                </div>

                <div class="space-y-3">
                  <p class="font-[family-name:var(--font-headline)] font-bold text-[10px] uppercase tracking-[0.25em] text-text-muted">
                    Programme
                  </p>
                  <div class="space-y-2">
                    {f.modules.map((m) => (
                      <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-base flex-shrink-0"
                          style={`color:${f.accentLight}; font-size:16px; font-variation-settings:'FILL' 0,'wght' 300`}>
                          {m.icon}
                        </span>
                        <span class="font-[family-name:var(--font-body)] text-sm text-text-secondary">{m.label}</span>
                      </div>
                    ))}
                  </div>
                </div>

                <div class="flex items-center gap-3 pt-2 border-t border-white/5 mt-auto">
                  <button
                    class="flex items-center gap-2 px-5 py-2.5 rounded-xl font-[family-name:var(--font-headline)] font-bold text-[11px] uppercase tracking-widest text-white transition-all hover:scale-105 active:scale-95"
                    style={`background:${f.accent}; box-shadow: 0 0 20px ${f.accent}50`}
                  >
                    <span class="material-symbols-outlined text-base">edit</span>
                    Gérer
                  </button>
                  <button
                    class="flex items-center gap-2 px-5 py-2.5 rounded-xl font-[family-name:var(--font-headline)] font-bold text-[11px] uppercase tracking-widest text-text-secondary bg-white/5 border border-white/10 hover:bg-white/10 hover:text-white transition-all"
                  >
                    <span class="material-symbols-outlined text-base">group</span>
                    Inscrits HubSpot
                  </button>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>


      <!-- ═══ TAB : COACHING ═══════════════════════ -->
      <div id="tab-coaching" class="flex-1 flex flex-col items-center justify-center gap-5 p-8" style="display:none">
        <div class="w-16 h-16 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center">
          <span class="material-symbols-outlined text-3xl text-text-muted">handshake</span>
        </div>
        <div class="text-center space-y-2">
          <p class="font-[family-name:var(--font-headline)] font-black text-2xl uppercase tracking-[0.1em] text-white">Coaching</p>
          <p class="font-[family-name:var(--font-body)] text-sm text-text-secondary">Prochainement — Sessions, clients actifs & suivi</p>
        </div>
      </div>


      <!-- ═══ TAB : HUBSPOT ════════════════════════ -->
      <div id="tab-hubspot" class="flex-1 p-8 space-y-8" style="display:none">
        {hubspot.connected ? (
          <>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <span class="w-2 h-2 rounded-full bg-tertiary"></span>
                <span class="font-[family-name:var(--font-headline)] font-bold text-xs uppercase tracking-[0.2em] text-tertiary">HubSpot connecté</span>
              </div>
              <p class="font-[family-name:var(--font-body)] text-xs text-text-muted">
                Données au {hubspot.builtAt}
              </p>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div class="glass-card rounded-2xl p-6 border border-white/5 space-y-1">
                <p class="font-[family-name:var(--font-body)] text-[10px] uppercase tracking-[0.25em] text-text-muted">Contacts</p>
                <p class="font-[family-name:var(--font-headline)] font-black text-5xl text-white">{hubspot.totalContacts}</p>
                <p class="font-[family-name:var(--font-body)] text-xs text-text-secondary">Dans ton CRM</p>
              </div>
              <div class="glass-card rounded-2xl p-6 border border-white/5 space-y-1">
                <p class="font-[family-name:var(--font-body)] text-[10px] uppercase tracking-[0.25em] text-text-muted">Deals</p>
                <p class="font-[family-name:var(--font-headline)] font-black text-5xl text-white">{hubspot.totalDeals}</p>
                <p class="font-[family-name:var(--font-body)] text-xs text-text-secondary">Opportunités</p>
              </div>
            </div>
            <div class="space-y-4">
              <h2 class="font-[family-name:var(--font-headline)] font-black text-xl uppercase tracking-[0.15em] text-white">
                Contacts récents
              </h2>
              <div class="glass-panel rounded-2xl border border-white/5 overflow-hidden">
                {hubspot.recentContacts.length > 0 ? (
                  <table class="w-full">
                    <thead>
                      <tr class="border-b border-white/5">
                        <th class="text-left px-6 py-4 font-[family-name:var(--font-headline)] font-bold text-[10px] uppercase tracking-[0.2em] text-text-muted">Nom</th>
                        <th class="text-left px-6 py-4 font-[family-name:var(--font-headline)] font-bold text-[10px] uppercase tracking-[0.2em] text-text-muted">Email</th>
                        <th class="text-right px-6 py-4 font-[family-name:var(--font-headline)] font-bold text-[10px] uppercase tracking-[0.2em] text-text-muted">Ajouté</th>
                      </tr>
                    </thead>
                    <tbody>
                      {hubspot.recentContacts.map((c, i) => (
                        <tr class={`border-b border-white/5 hover:bg-white/3 transition-colors ${i === hubspot.recentContacts.length - 1 ? 'border-0' : ''}`}>
                          <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                              <div class="w-8 h-8 rounded-full gradient-cta flex items-center justify-center text-white text-xs font-bold flex-shrink-0 font-[family-name:var(--font-headline)]">
                                {contactName(c).charAt(0).toUpperCase()}
                              </div>
                              <span class="font-[family-name:var(--font-body)] text-sm text-white">{contactName(c)}</span>
                            </div>
                          </td>
                          <td class="px-6 py-4 font-[family-name:var(--font-body)] text-sm text-text-secondary">
                            {c.properties.email ?? '—'}
                          </td>
                          <td class="px-6 py-4 text-right font-[family-name:var(--font-body)] text-xs text-text-muted">
                            {relDate(c.properties.createdate)}
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                ) : (
                  <div class="p-8 text-center">
                    <p class="font-[family-name:var(--font-body)] text-sm text-text-secondary">Aucun contact trouvé</p>
                  </div>
                )}
              </div>
            </div>
          </>
        ) : (
          <div class="flex flex-col items-center justify-center h-full gap-6 py-24">
            <div class="w-16 h-16 rounded-2xl bg-secondary/10 border border-secondary/20 flex items-center justify-center">
              <span class="material-symbols-outlined text-3xl text-secondary-light">contacts</span>
            </div>
            <div class="text-center space-y-2">
              <p class="font-[family-name:var(--font-headline)] font-black text-2xl uppercase tracking-[0.1em] text-white">CRM HubSpot</p>
              {hubspot.error ? (
                <p class="font-[family-name:var(--font-body)] text-sm max-w-sm" style="color:#ffb4ab">{hubspot.error}</p>
              ) : (
                <p class="font-[family-name:var(--font-body)] text-sm text-text-secondary max-w-sm">
                  Token HubSpot manquant — ajoute HUBSPOT_TOKEN dans le fichier .env
                </p>
              )}
            </div>
          </div>
        )}
      </div>


      <!-- ═══ TAB : CONTENU ════════════════════════ -->
      <div id="tab-contenu" class="flex-1 flex flex-col items-center justify-center gap-5 p-8" style="display:none">
        <div class="w-16 h-16 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center">
          <span class="material-symbols-outlined text-3xl text-text-muted">video_library</span>
        </div>
        <div class="text-center space-y-2">
          <p class="font-[family-name:var(--font-headline)] font-black text-2xl uppercase tracking-[0.1em] text-white">Contenu</p>
          <p class="font-[family-name:var(--font-body)] text-sm text-text-secondary">Prochainement — YouTube, LinkedIn & métriques</p>
        </div>
      </div>


      <!-- ═══ TAB : AUTOMATION ══════════════════════ -->
      <div id="tab-automation" class="flex-1 flex flex-col items-center justify-center gap-5 p-8" style="display:none">
        <div class="w-16 h-16 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center">
          <span class="material-symbols-outlined text-3xl text-text-muted">hub</span>
        </div>
        <div class="text-center space-y-2">
          <p class="font-[family-name:var(--font-headline)] font-black text-2xl uppercase tracking-[0.1em] text-white">Automatisation n8n</p>
          <p class="font-[family-name:var(--font-body)] text-sm text-text-secondary">Prochainement — Workflows actifs & monitoring</p>
        </div>
      </div>

    </main>
  </div>

  <!-- Script onglets uniquement (aucune logique d'auth) -->
  <script>
    const pageTitleEl = document.getElementById('page-title');
    const dateEl      = document.getElementById('current-date');

    if (dateEl) {
      dateEl.textContent = new Date().toLocaleDateString('fr-FR', {
        weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
      });
    }

    const tabs: Record<string, HTMLElement | null> = {
      formations: document.getElementById('tab-formations'),
      coaching:   document.getElementById('tab-coaching'),
      hubspot:    document.getElementById('tab-hubspot'),
      contenu:    document.getElementById('tab-contenu'),
      automation: document.getElementById('tab-automation'),
    };
    const tabLabels: Record<string, string> = {
      formations: 'Formations',
      coaching:   'Coaching',
      hubspot:    'CRM HubSpot',
      contenu:    'Contenu',
      automation: 'Automatisation n8n',
    };

    function activateTab(name: string) {
      for (const [key, el] of Object.entries(tabs)) {
        if (el) el.style.display = key === name ? '' : 'none';
      }
      if (pageTitleEl) pageTitleEl.textContent = tabLabels[name] || name;
      document.querySelectorAll<HTMLElement>('.tab-btn').forEach(btn => {
        const isActive = btn.dataset.tab === name;
        btn.style.background   = isActive ? 'rgba(53,36,232,0.12)' : '';
        btn.style.color        = isActive ? '#ffffff' : '';
        const icon = btn.querySelector<HTMLElement>('.material-symbols-outlined');
        if (icon) icon.style.color = isActive ? '#c2c1ff' : '';
      });
    }

    document.querySelectorAll<HTMLElement>('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => activateTab(btn.dataset.tab ?? 'formations'));
    });

    activateTab('formations');
  </script>

)}

</DashboardLayout>
