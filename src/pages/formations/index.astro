---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactSection from '../../components/ContactSection.astro';

const formations = [
  // ── Formations réelles 2026 ──────────────────────────────────────────────
  {
    title: 'Maîtriser Claude',
    slug: 'maitriser-claude-avril-2026',
    description: "Formation complète sur Claude et son environnement : Excel, PowerPoint, artefacts, Claude Code, NanoBanana, second cerveau IA et comparatif des LLMs.",
    price: 'Nous contacter',
    rating: 'Nouveau',
    level: '29 Avr — Robelot',
    levelColor: 'primary-light',
    icon: 'psychology',
    iconGradient: 'from-primary/40 to-bg-surface',
    date: 'Mercredi 29 avril 2026',
    isNew: true,
  },
  {
    title: 'Maîtriser Claude',
    slug: 'maitriser-claude-mai-2026',
    description: "Formation complète sur Claude et son environnement : Excel, PowerPoint, artefacts, Claude Code, NanoBanana, second cerveau IA et comparatif des LLMs.",
    price: 'Nous contacter',
    rating: 'Nouveau',
    level: '20 Mai — Robelot',
    levelColor: 'secondary-light',
    icon: 'psychology',
    iconGradient: 'from-secondary/40 to-bg-surface',
    date: 'Mercredi 20 mai 2026',
    isNew: true,
  },
  // ── Catalogue en ligne ───────────────────────────────────────────────────
  {
    title: 'Prompt Engineering Pro',
    slug: 'prompt-engineering',
    description: "L'art de sculpter l'intelligence artificielle pour des résultats professionnels précis et reproductibles.",
    price: '899€',
    rating: '4.9',
    level: 'Avancé',
    levelColor: 'tertiary',
    icon: 'terminal',
    iconGradient: 'from-primary/30 to-bg-surface',
  },
  {
    title: 'Product Manager IA',
    slug: 'product-manager-ia',
    description: "Intégrez l'IA dans votre roadmap produit et gérez le cycle de vie de produits augmentés par l'IA.",
    price: '1 250€',
    rating: '4.8',
    level: 'Leadership',
    levelColor: 'secondary-light',
    icon: 'analytics',
    iconGradient: 'from-secondary/30 to-bg-surface',
  },
  {
    title: 'No-Code AI Architect',
    slug: 'no-code-ia',
    description: "Construisez des applications IA complètes sans une seule ligne de code. Orchestrez des workflows multi-agents.",
    price: '650€',
    rating: '5.0',
    level: 'No-Code',
    levelColor: 'primary-light',
    icon: 'auto_awesome',
    iconGradient: 'from-primary-light/20 to-bg-surface',
  },
  {
    title: 'IA Éthique & Responsable',
    slug: 'ia-ethique',
    description: "Explorez le cadre éthique de l'IA. Apprenez les protocoles de sécurité et les frameworks de déploiement responsable.",
    price: '540€',
    rating: '4.7',
    level: 'Fondamentaux',
    levelColor: 'tertiary',
    icon: 'security',
    iconGradient: 'from-tertiary/30 to-bg-surface',
  },
];

const categories = ['Toutes', 'Produit', 'Engineering', 'Stratégie'];

const coursesSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Formations IA — The French Bot",
  "description": "Catalogue de formations en intelligence artificielle, coaching IA et automatisation no-code pour professionnels en France.",
  "url": "https://thefrenchbot.com/formations",
  "itemListElement": formations.map((f, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "Course",
      "name": f.title,
      "description": f.description,
      "url": `https://thefrenchbot.com/formations/${f.slug}`,
      "provider": {
        "@type": "Organization",
        "name": "The French Bot",
        "url": "https://thefrenchbot.com"
      },
      "inLanguage": "fr",
      "courseMode": "blended",
      "offers": f.price !== 'Nous contacter' ? {
        "@type": "Offer",
        "price": f.price.replace('€', '').replace(' ', ''),
        "priceCurrency": "EUR"
      } : undefined
    }
  }))
};
---

<BaseLayout
  title="Formations IA en France | Coaching IA & Automatisation — The French Bot"
  description="Découvrez toutes nos formations IA : Claude Code, Prompt Engineering, No-Code, automatisation. Formations IA en présentiel et en ligne pour professionnels et dirigeants. Financement OPCO disponible."
  pageSchema={coursesSchema}
>
  <!-- Header Section -->
  <section class="pt-32 pb-12 md:pb-20 px-6 md:px-12 max-w-[1440px] mx-auto">
    <header class="mb-16 md:mb-20 text-center md:text-left">
      <h1 class="font-[family-name:var(--font-headline)] font-black text-4xl sm:text-5xl md:text-7xl mb-6 uppercase tracking-tight leading-none">
        Nos <span class="gradient-text">Formations</span>
      </h1>
      <p class="font-[family-name:var(--font-body)] text-text-secondary max-w-2xl text-lg leading-relaxed">
        Maîtrisez les outils de demain. Nos programmes sont conçus par des experts pour combler le fossé entre intuition humaine et intelligence artificielle.
      </p>
    </header>

    <!-- Filter Bar -->
    <div class="flex flex-col md:flex-row gap-6 mb-12 md:mb-16 items-center justify-between">
      <div class="flex flex-wrap gap-3">
        {categories.map((cat, i) => (
          <button
            class:list={[
              'px-5 py-3 rounded-full text-xs font-[family-name:var(--font-label)] font-semibold tracking-wider uppercase transition-colors',
              i === 0
                ? 'bg-primary text-white'
                : 'bg-bg-surface-high text-text-secondary hover:bg-bg-surface-highest',
            ]}
          >
            {cat}
          </button>
        ))}
      </div>
      <div class="relative w-full md:w-72">
        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-text-muted text-sm">search</span>
        <input
          type="text"
          placeholder="Rechercher une formation..."
          class="w-full bg-bg-surface border-none ring-1 ring-outline-variant/20 rounded-full py-3 pl-11 pr-4 text-sm focus:ring-primary transition-all font-[family-name:var(--font-body)] text-text-primary placeholder:text-text-muted"
        />
      </div>
    </div>

    <!-- Formations Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {formations.map((f) => (
        <a
          href={`/formations/${f.slug}`}
          class="glass-card rounded-xl overflow-hidden flex flex-col group hover:scale-[1.02] transition-all duration-500 border border-white/5"
        >
          <div class={`h-48 relative overflow-hidden bg-gradient-to-br ${f.iconGradient} flex items-center justify-center`}>
            <span class="material-symbols-outlined text-primary-light text-6xl group-hover:scale-110 transition-transform duration-500 opacity-60 group-hover:opacity-100">
              {f.icon}
            </span>
            <div class="absolute inset-0 bg-gradient-to-t from-bg-base to-transparent"></div>
            <div class="absolute bottom-4 left-4 flex gap-2">
              <span class={`px-3 py-1 bg-${f.levelColor}/10 backdrop-blur-md text-${f.levelColor} text-[10px] font-bold rounded-full border border-${f.levelColor}/20 uppercase tracking-widest`}>
                {f.level}
              </span>
            </div>
          </div>
          <div class="p-8 flex-grow flex flex-col">
            <div class="flex justify-between items-start mb-4">
              <h3 class="font-[family-name:var(--font-headline)] font-black text-2xl text-white group-hover:text-primary-light transition-colors uppercase tracking-tight">
                {f.title}
              </h3>
              {(f as any).isNew ? (
                <span class="px-2 py-1 rounded-full text-[9px] font-[family-name:var(--font-headline)] font-black uppercase tracking-widest gradient-cta text-white">Nouveau</span>
              ) : (
                <div class="flex items-center gap-1 text-secondary-light">
                  <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
                  <span class="text-xs font-bold">{f.rating}</span>
                </div>
              )}
            </div>
            {(f as any).date && (
              <div class="flex items-center gap-2 mb-3">
                <span class="material-symbols-outlined text-sm text-primary-light">calendar_today</span>
                <span class="font-[family-name:var(--font-headline)] font-bold text-xs uppercase tracking-wider text-primary-light">{(f as any).date}</span>
              </div>
            )}
            <p class="font-[family-name:var(--font-body)] text-text-secondary text-sm leading-relaxed mb-8">
              {f.description}
            </p>
            <div class="mt-auto pt-6 flex items-center justify-between">
              <span class="text-2xl font-[family-name:var(--font-headline)] font-black text-white">{f.price}</span>
              <span class="neon-glow bg-primary hover:bg-primary-hover text-white px-6 py-4 rounded-full text-xs font-bold uppercase tracking-widest transition-all">
                Voir le programme
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Contact -->
  <ContactSection />
</BaseLayout>
