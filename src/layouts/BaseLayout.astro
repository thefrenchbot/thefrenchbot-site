---
import '../styles/globals.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  pageSchema?: object | object[];
}

const {
  title,
  description = "Formation IA en France — The French Bot forme les professionnels à l'intelligence artificielle, l'automatisation no-code et Claude. Coaching IA personnalisé pour TPE et PME.",
  ogImage = '/images/og-default.jpg',
  pageSchema,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="fr" class="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <!-- SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="fr_FR" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Mr+Dafoe&family=Outfit:wght@300;400;600;800&family=Space+Grotesk:wght@300;500;700;900&family=Patrick+Hand&display=swap"
    rel="stylesheet"
  />

  <!-- Material Symbols -->
  <link
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
    rel="stylesheet"
  />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Entity schema: Organization + Person -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://thefrenchbot.com/#organization",
        "name": "The French Bot",
        "url": "https://thefrenchbot.com",
        "logo": {
          "@type": "ImageObject",
          "url": "https://thefrenchbot.com/images/og-default.jpg"
        },
        "description": "Organisme de formation IA en France. Coaching IA, accompagnement IA et automatisation no-code pour dirigeants de TPE et PME.",
        "foundingDate": "2023",
        "areaServed": {
          "@type": "Country",
          "name": "France"
        },
        "knowsAbout": ["Formation IA", "Coaching IA", "Accompagnement IA", "Automatisation no-code", "Claude Code", "ChatGPT", "Make", "Zapier", "Prompt engineering"],
        "sameAs": [
          "https://www.instagram.com/media_machines",
          "https://www.linkedin.com/in/julianluneau",
          "https://www.youtube.com/@thefrenchbot"
        ],
        "contactPoint": {
          "@type": "ContactPoint",
          "email": "contact@thefrenchbot.com",
          "contactType": "customer service",
          "availableLanguage": "French"
        }
      },
      {
        "@type": "Person",
        "@id": "https://thefrenchbot.com/#person",
        "name": "Julian Luneau",
        "jobTitle": "Formateur IA & Coach en Intelligence Artificielle",
        "worksFor": { "@id": "https://thefrenchbot.com/#organization" },
        "knowsAbout": ["Formation IA", "Coaching IA", "Automatisation no-code", "Claude Code", "Make", "Prompt engineering"],
        "url": "https://thefrenchbot.com",
        "sameAs": [
          "https://www.instagram.com/media_machines",
          "https://www.linkedin.com/in/julianluneau"
        ]
      }
    ]
  })} />

  <!-- Page-level schema (Course, FAQ, etc.) -->
  {pageSchema && (Array.isArray(pageSchema) ? pageSchema : [pageSchema]).map(schema =>
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />

  <!-- POPUP FORMATIONS CLAUDE -->
  <div id="popup-overlay" style="
    position:fixed; inset:0; z-index:9999;
    background:rgba(11,10,20,0.75); backdrop-filter:blur(6px);
    display:flex; align-items:center; justify-content:center;
    padding:16px;
    opacity:0; pointer-events:none;
    transition:opacity 0.4s ease;
  ">
    <div id="popup-card" style="
      position:relative;
      background:linear-gradient(135deg,#13121c 0%,#1c1a25 100%);
      border:1px solid #3524E8;
      border-radius:24px;
      padding:40px 36px 32px;
      max-width:480px; width:100%;
      box-shadow:0 0 60px rgba(53,36,232,0.35), 0 0 120px rgba(199,0,211,0.15);
      transform:translateY(24px) scale(0.97);
      transition:transform 0.4s cubic-bezier(0.34,1.56,0.64,1);
      text-align:center;
      font-family:'Outfit',sans-serif;
      color:#e5e0f0;
    ">
      <!-- Close -->
      <button id="popup-close" aria-label="Fermer" style="
        position:absolute; top:14px; right:16px;
        background:none; border:none; cursor:pointer;
        color:#908fa2; font-size:22px; line-height:1;
        transition:color 0.2s;
      " onmouseover="this.style.color='#e5e0f0'" onmouseout="this.style.color='#908fa2'">✕</button>

      <!-- Badge -->
      <div style="
        display:inline-flex; align-items:center; gap:6px;
        background:linear-gradient(90deg,#3524E8,#C700D3);
        border-radius:100px; padding:4px 16px;
        font-size:0.72rem; font-weight:700; letter-spacing:0.12em;
        text-transform:uppercase; color:#fff;
        margin-bottom:20px;
      ">🔥 Places limitées</div>

      <!-- Title -->
      <div style="font-size:2rem; margin-bottom:6px;">🤖</div>
      <h2 style="
        font-family:'Space Grotesk',sans-serif;
        font-size:1.55rem; font-weight:900;
        line-height:1.2; margin-bottom:8px;
        color:#fff;
      ">Maîtrisez Claude.<br>Pour de vrai.</h2>
      <p style="font-size:0.95rem; color:#c7c4d9; margin-bottom:28px; line-height:1.6;">
        Deux sessions intensives pour passer de curieux à expert.<br>Choisissez votre date 👇
      </p>

      <!-- Dates -->
      <div style="display:flex; gap:12px; margin-bottom:28px; flex-wrap:wrap; justify-content:center;">

        <div style="
          flex:1; min-width:160px;
          background:#1c1a25;
          border:1px solid #3524E8;
          border-radius:16px; padding:18px 14px;
          position:relative; overflow:hidden;
        ">
          <div style="
            position:absolute; top:0; left:0; right:0; height:3px;
            background:linear-gradient(90deg,#3524E8,#64d8d9);
          "></div>
          <div style="font-size:1.6rem; margin-bottom:6px;">📅</div>
          <div style="font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#bcbbff; margin-bottom:4px;">Session 1</div>
          <div style="font-size:1.05rem; font-weight:800; color:#fff;">Mercredi</div>
          <div style="font-size:1.5rem; font-weight:900; color:#64d8d9; line-height:1.1;">29 avril</div>
        </div>

        <div style="
          flex:1; min-width:160px;
          background:#1c1a25;
          border:1px solid #C700D3;
          border-radius:16px; padding:18px 14px;
          position:relative; overflow:hidden;
        ">
          <div style="
            position:absolute; top:0; left:0; right:0; height:3px;
            background:linear-gradient(90deg,#C700D3,#ffa9fb);
          "></div>
          <div style="font-size:1.6rem; margin-bottom:6px;">🗓️</div>
          <div style="font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#ffa9fb; margin-bottom:4px;">Session 2</div>
          <div style="font-size:1.05rem; font-weight:800; color:#fff;">Mercredi</div>
          <div style="font-size:1.5rem; font-weight:900; color:#ffa9fb; line-height:1.1;">20 mai</div>
        </div>

      </div>

      <!-- CTA -->
      <a href="https://calendly.com/thefrenchbot-coaching/30min" target="_blank" rel="noopener" style="
        display:inline-flex; align-items:center; gap:8px;
        background:linear-gradient(90deg,#3524E8,#C700D3);
        color:#fff; font-weight:700; font-size:1rem;
        padding:14px 32px; border-radius:100px;
        text-decoration:none;
        box-shadow:0 4px 24px rgba(53,36,232,0.4);
        transition:transform 0.2s, box-shadow 0.2s;
        margin-bottom:14px;
      "
      onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 32px rgba(53,36,232,0.5)'"
      onmouseout="this.style.transform='none';this.style.boxShadow='0 4px 24px rgba(53,36,232,0.4)'"
      >
        ✨ Je réserve ma place
      </a>

      <p style="font-size:0.78rem; color:#908fa2;">Appel découverte gratuit · Sans engagement</p>
    </div>
  </div>

  <script>
    (function() {
      const SESSION_KEY = 'tfb_popup_seen';
      if (sessionStorage.getItem(SESSION_KEY)) return;

      const overlay = document.getElementById('popup-overlay');
      const card = document.getElementById('popup-card');
      const closeBtn = document.getElementById('popup-close');

      function openPopup() {
        overlay.style.opacity = '1';
        overlay.style.pointerEvents = 'auto';
        card.style.transform = 'translateY(0) scale(1)';
        sessionStorage.setItem(SESSION_KEY, '1');
      }

      function closePopup() {
        overlay.style.opacity = '0';
        overlay.style.pointerEvents = 'none';
        card.style.transform = 'translateY(24px) scale(0.97)';
      }

      setTimeout(openPopup, 1800);

      closeBtn.addEventListener('click', closePopup);
      overlay.addEventListener('click', function(e) {
        if (e.target === overlay) closePopup();
      });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closePopup();
      });
    })();
  </script>
</body>
</html>
